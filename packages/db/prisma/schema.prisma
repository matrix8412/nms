generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                UserRole             @default(USER)
  emailVerifiedAt     DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  groupMemberships    GroupMember[]
  sessions            Session[]
  auditLogs           AuditLog[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
}

model Group {
  id            String              @id @default(cuid())
  name          String              @unique
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  members       GroupMember[]
  deviceAccess  GroupDeviceAccess[]
}

model GroupMember {
  userId      String
  groupId     String
  roleInGroup String?
  joinedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
}

model Device {
  id            String            @id @default(cuid())
  name          String
  ip            String            @unique
  vendor        String?
  type          String?
  zabbixHostId  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  groups        DeviceGroupDevice[]
  metrics       DeviceMetric[]
}

model DeviceGroup {
  id          String              @id @default(cuid())
  name        String              @unique
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  devices     DeviceGroupDevice[]
  access      GroupDeviceAccess[]
}

model DeviceGroupDevice {
  deviceId      String
  deviceGroupId String
  device        Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceGroup   DeviceGroup @relation(fields: [deviceGroupId], references: [id], onDelete: Cascade)

  @@id([deviceId, deviceGroupId])
  @@index([deviceGroupId])
}

model GroupDeviceAccess {
  groupId       String
  deviceGroupId String
  createdAt     DateTime    @default(now())
  group         Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  deviceGroup   DeviceGroup @relation(fields: [deviceGroupId], references: [id], onDelete: Cascade)

  @@id([groupId, deviceGroupId])
  @@index([deviceGroupId])
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  sessionTokenHash String   @unique
  csrfSecret       String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model VerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  consumedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  consumedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  meta      Json?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model DeviceMetric {
  id           BigInt   @default(autoincrement())
  deviceId     String
  source       String
  itemKey      String
  itemName     String?
  valueNumeric Float?
  valueText    String?
  recordedAt   DateTime @default(now())
  metadata     Json?
  device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@id([id, recordedAt])
  @@index([deviceId, recordedAt(sort: Desc)])
  @@index([itemKey, recordedAt(sort: Desc)])
}

model ZabbixItemMapping {
  id         String   @id @default(cuid())
  vendor     String?
  deviceType String?
  itemKey    String
  itemName   String?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([vendor, deviceType])
  @@unique([vendor, deviceType, itemKey])
}

// ── Catalog: Vendors & Device Types ─────────────────────────

model Vendor {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeviceType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Integration Settings ────────────────────────────────────

model IntegrationConfig {
  id           String   @id @default(cuid())
  provider     String   @unique          // e.g. "zabbix"
  enabled      Boolean  @default(false)
  settings     Json     @default("{}")   // provider-specific JSON blob
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Role-based permissions ──────────────────────────────────

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  builtIn     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
}

model RolePermission {
  id       String @id @default(cuid())
  roleId   String
  resource String              // e.g. "hosts", "users", "settings"
  action   String              // e.g. "read", "create", "update", "delete"
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@index([roleId])
}
