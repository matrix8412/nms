{
  "name": "@nms/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsup src/client.ts --format esm,cjs --dts",
    "dev": "tsup src/client.ts --format esm,cjs --dts --watch",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "bcryptjs": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "dotenv": "^16.6.1",
    "prisma": "^6.16.3",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
