{
  "name": "nms-system",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "corepack pnpm --filter @nms/db run prisma:deploy",
    "db:generate": "corepack pnpm --filter @nms/db run prisma:generate",
    "db:seed": "corepack pnpm --filter @nms/db run prisma:seed",
    "db:backfill-snmp-secrets": "corepack pnpm --filter @nms/db run prisma:backfill-snmp-secrets"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  }
}
