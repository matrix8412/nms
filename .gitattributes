# Auto-detect text files and normalise to LF in the repo
* text=auto eol=lf

# Force LF for files that MUST have unix line endings on Linux servers
*.sh text eol=lf
*.bash text eol=lf
Dockerfile* text eol=lf
docker-compose*.yml text eol=lf
*.conf text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.prisma text eol=lf

# Binary files — do not touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.gz binary
*.tar binary
*.zip binary
